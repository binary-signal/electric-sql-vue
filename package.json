{
  "name": "@electric-sql/vue",
  "version": "0.0.1",
  "description": "Vue 3 composables for Electric SQL",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "peerDependencies": {
    "vue": ">=3.3.0",
    "@electric-sql/client": "^1.0.0"
  },
  "devDependencies": {
    "vue": "^3.5.0",
    "@electric-sql/client": "^1.0.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0",
    "@vue/test-utils": "^2.4.0",
    "typescript": "^5.7.0",
    "vite-plugin-dts": "^4.0.0",
    "oxlint": "^0.16.0"
  },
  "scripts": {
    "dev": "vite --config playground/vite.config.ts",
    "build": "vite build",
    "test": "vitest",
    "lint": "oxlint src/"
  },
  "license": "Apache-2.0"
}
