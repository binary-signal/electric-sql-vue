{
  "name": "@binary-signal/electric-sql-vue",
  "version": "0.1.0",
  "description": "Vue 3 composables for Electric SQL — reactive shape subscriptions with automatic sync",
  "keywords": [
    "composable",
    "electric-sql",
    "reactive",
    "real-time",
    "sync",
    "vue"
  ],
  "homepage": "https://github.com/binary-signal/electric-sql-vue",
  "bugs": {
    "url": "https://github.com/binary-signal/electric-sql-vue/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/binary-signal/electric-sql-vue.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite --config playground/vite.config.ts",
    "build": "vite build",
    "test": "vitest",
    "lint": "oxlint src/",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@electric-sql/client": "^1.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.1.4",
    "vue": "^3.5.0"
  },
  "peerDependencies": {
    "@electric-sql/client": "^1.0.0",
    "vue": ">=3.3.0"
  }
}
